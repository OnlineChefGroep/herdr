{
  "name": "herdr-website",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-docs": "node scripts/prepare-docs.mjs",
    "dev": "node scripts/prepare-docs.mjs && astro dev",
    "test": "node --experimental-strip-types --test src/docs-path.test.ts",
    "build": "npm test && node scripts/prepare-docs.mjs && astro build",
    "preview": "astro preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0"
  }
}
