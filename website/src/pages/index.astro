---
import { readFile } from 'node:fs/promises';
import path from 'node:path';

// Resolve from the website package root. `import.meta.url` is unreliable here
// because Astro prerender relocates this module under `dist/.prerender/chunks/`.
const homepage = await readFile(path.join(process.cwd(), 'index.html'), 'utf8');
---

<Fragment set:html={homepage} />
