{
  "name": "herdr-chef",
  "version": "0.7.1-chef",
  "private": true,
  "description": "OnlineChefGroep downstream distribution of Herdr terminal multiplexer",
  "scripts": {
    "doctor": "bun scripts/doctor.ts",
    "sync": "bun scripts/sync-upstream.ts",
    "build": "cargo build --release",
    "test": "cargo nextest run",
    "lint": "cargo clippy -- -D warnings",
    "fmt": "cargo fmt --check",
